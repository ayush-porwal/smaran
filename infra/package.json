{
  "name": "smaran-infra",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK infrastructure for smaran (group list-sharing app)",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "synth": "cdk synth",
    "synth:local": "cdklocal synth --app 'npx ts-node --prefer-ts-exts bin/local.ts'",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@smaran/eslint-config": "*",
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1126.0",
    "aws-cdk-local": "^3.0.4",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1072.0",
    "@aws-sdk/lib-dynamodb": "^3.1072.0",
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.5.0"
  }
}
